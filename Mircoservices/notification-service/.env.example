# Notification Service Environment Variables
# Copy this file to .env and update values for your environment

# Server Configuration
server.port=8082

# Database Configuration
# MongoDB connection string (required)
# Example: mongodb://user:password@host:port/database
MONGODB_URI=mongodb://localhost:27017/notification_service

# Email Configuration (Gmail SMTP)
# For Gmail: Enable "Less secure app access" or use App Passwords
# MAIL_USERNAME: Your Gmail address or app email
# MAIL_PASSWORD: Your Gmail password or app-specific password
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_app_password_or_password
