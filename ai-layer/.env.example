# Application Settings
APP_NAME=Smart AI Matching Service
APP_VERSION=1.0.0
MODEL_NAME=all-MiniLM-L6-v2

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
LOG_LEVEL=INFO
WORKERS=1
RELOAD=False

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost:5000"]

# AI/ML Configuration
MODEL_CACHE_DIR=./models
PRELOAD_MODELS_ON_STARTUP=True
MAX_WORKERS=4

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/ai_matching_service
