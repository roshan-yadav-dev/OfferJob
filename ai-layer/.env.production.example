# AI Layer Production Environment Variables
# Update these values for production deployment

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
LOG_LEVEL=INFO

# Model Configuration
MODEL_NAME=all-MiniLM-L6-v2
MODEL_CACHE_DIR=/app/models
PRELOAD_MODELS_ON_STARTUP=True

# CORS Configuration
# Set to production domain(s)
# Format: JSON array or comma-separated values
# Example: '["https://yourapp.com", "https://api.yourapp.com"]'
# Or: https://yourapp.com,https://api.yourapp.com
CORS_ORIGINS=["https://yourdomain.com"]

# Database Configuration (if needed in future)
DATABASE_URL=mongodb://user:password@your-host:27017/ai_matching_service
