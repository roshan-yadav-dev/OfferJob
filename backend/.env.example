# Backend Environment Variables
# Copy this file to .env and update values for your environment

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# MongoDB connection string (required for production)
# Example: mongodb://user:password@host:port/database
MONGO_URI=mongodb+srv://Roshan:Roshan@cluster0.fie3eke.mongodb.net/job-service-portal


# JWT Configuration
# Generate a secure random string for production
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=b170ad6213a34bb3ad1e764e0672deb287d23475dc66f3f053af87cd443fd0ed
JWT_EXPIRE=7d

# CORS Configuration
# Frontend origin(s) that can make requests to this API
# For production, use your actual domain
CORS_ORIGIN=http://localhost:3000

# AI Service Configuration
# URL of the AI matching service
# Docker: http://ai-service:8000/api/v1/ai
# Local: http://localhost:8000/api/v1/ai
AI_SERVICE_URL=http://localhost:8000/api/v1/ai
AI_SERVICE_TIMEOUT=30000
AI_SERVICE_MAX_RETRIES=2
AI_SERVICE_RETRY_DELAY=1000

# Email Configuration (Brevo SMTP)
# Use Brevo SMTP credentials from your Brevo SMTP & API settings
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-smtp-login
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_FROM="Job Service Platform <verified-sender@example.com>"

# Logging
LOG_LEVEL=INFO

# Cloudinary Configuration
# Get credentials from: https://console.cloudinary.com/app/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
